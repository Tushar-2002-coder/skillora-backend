# ============================================
# Skillora Backend - Environment Variables
# ============================================
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to GitHub/Git.

# Your MongoDB Atlas connection string
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/skillora
MONGO_URI=your_mongodb_atlas_uri_here

# A long random secret string used to sign login tokens
# You can generate one at https://www.random.org/strings/ or just type a long random sentence
JWT_SECRET=replace_this_with_a_long_random_secret

# Port the backend server runs on
PORT=5000

# Google Sign-In Client ID (from Google Cloud Console -> Credentials)
GOOGLE_CLIENT_ID=665381937501-ifp6c5erg6ukptmv4s2fs52a7vabddor.apps.googleusercontent.com

# Email account used to SEND password reset emails (optional, for "Forgot Password")
# If using Gmail, you must create an "App Password" (not your normal password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Frontend URL (used to build password reset links)
CLIENT_URL=http://localhost:5173
